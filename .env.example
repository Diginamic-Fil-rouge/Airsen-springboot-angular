
ENV=local  # local, dev, test, staging, prod

# DOCKER BUILD TARGETS
BACKEND_TARGET=development
FRONTEND_TARGET=development

# SPRING BOOT CONFIGURATION
SPRING_PROFILES_ACTIVE=dev  # dev, test, prod
DDL_AUTO=update  # update, validate, create, create-drop
LOG_LEVEL=DEBUG  # TRACE, DEBUG, INFO, WARN, ERROR
CORS_ORIGINS=http://localhost:4200  # Comma-separated list

# PORT CONFIGURATION
BACKEND_PORT=8080
FRONTEND_PORT=4200
FRONTEND_INTERNAL_PORT=4200
DEBUG_PORT=5005  # Leave empty for production

# DATABASE CONFIGURATION
DB_HOST=mariadb  # Use service name for Docker, localhost for local
DB_PORT=3306
DB_NAME=airsen_dev
DB_USER=airsen_dev
DB_USERNAME=airsen_dev
DB_PASSWORD=dev_password
DB_ROOT_PASSWORD=root_local_dev_password

# JWT SECURITY
# Generate with: openssl rand -base64 32
JWT_SECRET=your_base64_encoded_secret_here

# EMAIL CONFIGURATION
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM_ADDRESS=noreply@airsen.fr
MAIL_FROM_NAME=Airsen Air Quality System

# ADMIN ACCOUNT
ADMIN_EMAIL=admin@airsen.local
ADMIN_PASSWORD=change_me_secure_password

# EXTERNAL APIs
ATMO_API_URL=https://admindata.atmo-france.org
ATMO_USERNAME=your_atmo_username
ATMO_PASSWORD=your_atmo_password
OPEN_METEO_URL=https://api.open-meteo.com/v1
INSEE_API_URL=https://geo.api.gouv.fr

# REDIS CONFIGURATION
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_TTL_ATMO=3600  # 1 hour in seconds
REDIS_TTL_WEATHER=1800  # 30 minutes in seconds
REDIS_TTL_INSEE=86400  # 24 hours in seconds

# ============================================================================
# SCHEDULING CONFIGURATION
# ============================================================================
# Master switch to enable/disable ALL scheduled tasks
# IMPORTANT for development: Set to false to prevent API rate limiting
ENABLE_SCHEDULING=false  # Set to true in production

# Tiered intelligent scheduler (population-based refresh)
# Reduces API calls by 98% (2.6M → 47K/day)
TIERED_SCHEDULER_ENABLED=false  # Enable in production for efficiency

# Alert detection scheduler
ALERT_DETECTION_ENABLED=false  # Enable in production

# ATMO Air Quality Sync Schedule
# Cron format: second minute hour day-of-month month day-of-week
# Development: 0 0 10 * * MON (Monday only)
# Production: 0 0 10 * * * (daily at 10 AM)
ATMO_SCHEDULE_CRON=0 0 10 * * MON
ATMO_SCHEDULE_TIMEZONE=Europe/Paris
ATMO_BATCH_SIZE=25  # Smaller batches for dev (production: 50)

# Weather Sync Schedule
# Development: 0 30 10 * * MON (Monday only, 30 min after ATMO)
# Production: 0 30 10 * * * (daily at 10:30 AM)
WEATHER_SCHEDULE_CRON=0 30 10 * * MON
WEATHER_SCHEDULE_TIMEZONE=Europe/Paris
WEATHER_BATCH_SIZE=10  # Smaller batches for dev (production: 100)
WEATHER_BATCH_DELAY=120000  # 2 minutes between batches in dev (production: 60000)
WEATHER_REQUEST_DELAY=12000  # 12 seconds between requests (5 req/min, production: 6000 for 10 req/min)
WEATHER_SAMPLE_SIZE=50  # Only update 50 communes in dev (production: -1 for all)
WEATHER_SAMPLE_STRATEGY=top-population  # 'random', 'top-population', or 'all'

# Cache Refresh Schedules (less frequent in dev)
CACHE_AIR_QUALITY_CRON=0 0 */6 * * *  # Every 6 hours (production: hourly)
CACHE_WEATHER_CRON=0 0 */3 * * *  # Every 3 hours (production: every 30 min)
CACHE_STATS_CRON=0 0 * * * *  # Hourly (production: every 15 min)
CACHE_CLEANUP_CRON=0 0 3 * * *  # Daily at 3 AM

# Alert Detection Schedule
ALERT_DETECTION_CRON=0 0 */6 * * *  # Every 6 hours (production: hourly)

# ============================================================================
# RATE LIMITING CONFIGURATION
# ============================================================================
# Conservative limits for development to prevent API exhaustion
# Production values are higher (see application-prod.yml)
ATMO_RATE_LIMIT=30  # requests per minute (production: 60)
WEATHER_RATE_LIMIT=5  # requests per minute (production: 10)
INSEE_RATE_LIMIT=10  # requests per minute (production: 30)

# API Timeouts (milliseconds)
ATMO_TIMEOUT=15000  # 15 seconds (production: 10000)
OPEN_METEO_TIMEOUT=30000  # 30 seconds (production: 20000)
INSEE_TIMEOUT=10000  # 10 seconds (production: 5000)

# Retry attempts
ATMO_RETRY=2  # production: 3
OPEN_METEO_RETRY=2  # production: 3
INSEE_RETRY=2  # production: 3

# FRONTEND CONFIGURATION
NODE_ENV=development  # development, production, test
API_BASE_URL=http://localhost:8080  # Backend API URL
CHOKIDAR_POLLING=true  # Enable for hot reload in Docker
WATCHPACK_POLLING=true  # Enable for hot reload in Docker

# DOCKER VOLUME MOUNTS
# Development: Mount source code for hot reload
# Production: Leave empty for immutable containers
BACKEND_VOLUME_MOUNT=./airsen-backend:/app
FRONTEND_VOLUME_MOUNT=./airsen-frontend:/app


# DOCKER COMMANDS
# Custom commands for different environments
BACKEND_COMMAND=mvn spring-boot:run -Dspring-boot.run.jvmArguments="-Xms256m -Xmx512m -agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=*:5005"
FRONTEND_COMMAND=sh -c "npm ci && npx ng serve --host 0.0.0.0 --port 4200 --poll 2000"


# DOCKER RESOURCE LIMITS
BACKEND_MEMORY_LIMIT=1G
BACKEND_MEMORY_RESERVE=512M
FRONTEND_MEMORY_LIMIT=2G
FRONTEND_MEMORY_RESERVE=1G
