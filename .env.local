# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_TTL_ATMO=3600    # 1 hour for air quality data
REDIS_TTL_WEATHER=1800 # 30 minutes for weather data
REDIS_TTL_INSEE=86400  # 24 hours for demographic data

# Scheduling Configuration - Automated Data Updates
# Cron format: second minute hour day-of-month month day-of-week
# Examples:
#   0 0 0 * * * = Every day at midnight (00:00:00)
#   0 30 0 * * * = Every day at 00:30:00
#   0 0 6 * * * = Every day at 6:00:00 AM
#   0 0 6,18 * * * = Every day at 6:00 AM and 6:00 PM
ATMO_SCHEDULE_CRON=0 0 0 * * *       # ATMO air quality sync at midnight
ATMO_SCHEDULE_TIMEZONE=Europe/Paris  # Timezone for ATMO scheduler
WEATHER_SCHEDULE_CRON=0 30 0 * * *   # Weather sync at 00:30 (staggered 30 minutes after ATMO)
WEATHER_SCHEDULE_TIMEZONE=Europe/Paris  # Timezone for weather scheduler


