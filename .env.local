# Active Spring profile (dev, test, prod)
SPRING_PROFILES_ACTIVE=dev
# Backend HTTP port (Spring Boot server.port)
BACKEND_PORT=8080

# Database Configuration - Local MariaDB Container
# If running via Docker Compose, use the service name (e.g., "mariadb").
# For local non-Docker, use "localhost".
DB_HOST=mariadb
DB_PORT=3306
DB_NAME=airsen_dev
DB_USER=airsen_dev
DB_USERNAME=airsen_dev
DB_PASSWORD=dev_password
# Root password only used by the DB container/init scripts; app should not use it.
DB_ROOT_PASSWORD=root_local_dev_password

