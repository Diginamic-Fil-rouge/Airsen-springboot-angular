# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_TTL_ATMO=3600    # 1 hour for air quality data
REDIS_TTL_WEATHER=1800 # 30 minutes for weather data  
REDIS_TTL_INSEE=86400  # 24 hours for demographic data

# MariaDB Docker Environment Variables
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=airsen_dev
MYSQL_USER=airsen_dev
MYSQL_PASSWORD=
# Encoding/Collation to ensure full Unicode support (emojis, etc.)
MARIADB_CHARACTER_SET_SERVER=utf8mb4
MARIADB_COLLATE_SERVER=utf8mb4_unicode_ci

# Frontend Configuration
NODE_ENV=development
API_BASE_URL=http://airsen-backend:8080/api/v1

