    }

    .profile-content {
      // Tighter spacing on mobile
      ::ng-deep .mat-mdc-tab-group {
        .mat-mdc-tab-labels {
          padding: 0 $space-3; // 12px
        }

        .mat-mdc-tab {
          min-width: 120px; // Smaller tabs on mobile
        }
      }

      .tab-content {
        padding: $space-3; // 12px
        min-height: 300px; // Shorter on mobile

        &.notifications-tab {
          .notifications-section,
          .preferences-section {
            padding: $space-4 $space-3; // 16px 12px
          }

          .notifications-list {
            gap: $space-3; // 12px (tighter on mobile)
          }
        }
      }
    }
  }
}
