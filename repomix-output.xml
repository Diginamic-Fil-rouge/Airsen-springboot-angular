  <div class="search-card">
    <mat-form-field appearance="outline" class="search-field">
      <mat-icon matPrefix class="search-icon">search</mat-icon>

      <input type="text" matInput [formControl]="searchControl" [placeholder]="placeholder"
        aria-label="Recherche de communes françaises" />

      <button mat-icon-button matSuffix type="button" class="action-btn" *ngIf="searchControl.value"
        (click)="clearSearch()" aria-label="Effacer la recherche">
        <mat-icon>close</mat-icon>
      </button>
    </mat-form-field>
  </div>

  <!-- Results Dropdown -->
  <ng-container *ngIf="filteredCommunes$ | async as communes">
    <div class="results-card"
      *ngIf="showResults && (communes.length > 0 || isLoading || (hasTyped && communes.length === 0) || searchError)">
      <!-- Cities Section -->
      <div class="results-section" *ngIf="communes.length > 0">
        <div class="results-list">
          <div class="result-item" *ngFor="let commune of communes" (click)="onCommuneSelected(commune)">
