        <mat-checkbox formControlName="acceptTerms" color="primary">
          <span class="checkbox-text">
            J'accepte les <a href="/terms" target="_blank">Conditions d'utilisation</a> et la
            <a href="/privacy" target="_blank">Politique de confidentialité</a>
          </span>
        </mat-checkbox>
        <div *ngIf="registerForm.get('acceptTerms')?.touched && registerForm.get('acceptTerms')?.invalid" class="field-error checkbox-error">
          Vous devez accepter les conditions d'utilisation
        </div>
      </div>

      <!-- Submit Button -->
      <button
        mat-raised-button
        color="primary"
        type="submit"
        class="submit-button full-width"
        [disabled]="(isLoading$ | async) || registerForm.invalid"
      >
        <span *ngIf="!(isLoading$ | async)">Créer un compte</span>
        <mat-spinner *ngIf="isLoading$ | async" diameter="20" class="button-spinner"></mat-spinner>
      </button>

      <!-- Login Link -->
      <div class="alternate-action">
        <p class="alternate-text">
          Vous avez déjà un compte ?
          <a routerLink="/auth/login" class="alternate-link">Se connecter ici</a>
        </p>
      </div>
    </form>

