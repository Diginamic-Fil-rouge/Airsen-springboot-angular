.favorite-button {
  border: none;
  background: transparent;
  cursor: pointer;
  transition: transform 0.2s ease, background-color 0.2s ease;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  position: relative;
  border-radius: 50%;
  padding: 8px;

  &.small {
    .mat-icon {
      font-size: 20px;
    }

    padding: 6px;
  }

  &.medium {
    .mat-icon {
      font-size: 24px;
    }

    padding: 8px;
  }

  &.large {
    .mat-icon {
      font-size: 32px;
    }

    padding: 10px;
  }

  .mat-icon {
    color: var(--airsen-gray-500);

    &.favorited {
      color: #f44336;
    }

    // Ensure proper styling when disabled at max limit
    &.disabled-icon {
      color: var(--airsen-gray-400);
      opacity: 0.7;
    }
  }

  // Only apply red background when favorited and not disabled
  &.is-favorited:not(:disabled) {
    background: rgba(244, 67, 54, 0.1);

    &:hover:not(:disabled) {
      transform: scale(1.1);
      background: rgba(244, 67, 54, 0.15);
    }
  }

  // For unfavorited items, use gray background on hover
  &:not(.is-favorited) {
    &:hover:not(:disabled) {
      transform: scale(1.1);
      background: rgba(158, 158, 158, 0.1);
    }
  }

  // Special styling when at max limit and not favorited
  &.at-max-limit {
    background: transparent !important;

    &:hover:not(:disabled) {
      background: transparent !important;
    }
  }

  &:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    background: transparent !important;

    // Ensure no green background when disabled, even if favorited
    &.is-favorited {
      background: transparent !important;
    }
  }

  &.animate-success .mat-icon {
    animation: heartBeat 0.3s ease;
  }

  .max-tooltip {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    margin-top: 4px;
    padding: 2px 6px;
    background: rgba(0, 0, 0, 0.75);
    color: #fff;
    font-size: 11px;
    border-radius: 4px;
    white-space: nowrap;
    pointer-events: none;
  }
}

@keyframes heartBeat {

  0%,
  100% {
    transform: scale(1);
  }

  50% {
    transform: scale(1.2);
  }
}
