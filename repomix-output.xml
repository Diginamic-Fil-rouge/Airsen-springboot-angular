  width: 12px;
  height: 12px;
  border-radius: $radius-full;
  background-color: $airsen-yellow-moderate;
  display: inline-block;
  box-shadow: 0 0 0 3px color.adjust($airsen-yellow-moderate, $lightness: 30%);
}

.aqi-indicator-sensitive {
  width: 12px;
  height: 12px;
  border-radius: $radius-full;
  background-color: $airsen-orange-sensitive;
  display: inline-block;
  box-shadow: 0 0 0 3px color.adjust($airsen-orange-sensitive, $lightness: 30%);
}

.aqi-indicator-unhealthy {
  width: 12px;
  height: 12px;
  border-radius: $radius-full;
  background-color: $airsen-red-unhealthy;
  display: inline-block;
  box-shadow: 0 0 0 3px color.adjust($airsen-red-unhealthy, $lightness: 30%);
}

.aqi-indicator-very-unhealthy {
  width: 12px;
  height: 12px;
  border-radius: $radius-full;
  background-color: $airsen-purple-very;
  display: inline-block;
  box-shadow: 0 0 0 3px color.adjust($airsen-purple-very, $lightness: 30%);
}

.aqi-indicator-hazardous {
  width: 12px;
  height: 12px;
  border-radius: $radius-full;
  background-color: $airsen-maroon-hazardous;
  display: inline-block;
  box-shadow: 0 0 0 3px color.adjust($airsen-maroon-hazardous, $lightness: 30%);
}

// AQI Background Utility Classes
.aqi-bg-good {
  background-color: color.adjust($airsen-green-good, $lightness: 45%);
  border-left: 4px solid $airsen-green-good;
}

.aqi-bg-moderate {
  background-color: color.adjust($airsen-yellow-moderate, $lightness: 35%);
  border-left: 4px solid $airsen-yellow-moderate;
}

.aqi-bg-sensitive {
  background-color: color.adjust($airsen-orange-sensitive, $lightness: 35%);
  border-left: 4px solid $airsen-orange-sensitive;
}

.aqi-bg-unhealthy {
  background-color: color.adjust($airsen-red-unhealthy, $lightness: 35%);
  border-left: 4px solid $airsen-red-unhealthy;
}

.aqi-bg-very-unhealthy {
  background-color: color.adjust($airsen-purple-very, $lightness: 40%);
  border-left: 4px solid $airsen-purple-very;
}

.aqi-bg-hazardous {
  background-color: color.adjust($airsen-maroon-hazardous, $lightness: 45%);
  border-left: 4px solid $airsen-maroon-hazardous;
}

// AQI Text Color Utility Classes
.aqi-text-good {
  color: $airsen-green-good;
  font-weight: $font-weight-semibold;
}

.aqi-text-moderate {
  color: $airsen-yellow-moderate;
  font-weight: $font-weight-semibold;
}

.aqi-text-sensitive {
  color: $airsen-orange-sensitive;
  font-weight: $font-weight-semibold;
}

.aqi-text-unhealthy {
  color: $airsen-red-unhealthy;
  font-weight: $font-weight-semibold;
}

.aqi-text-very-unhealthy {
  color: $airsen-purple-very;
  font-weight: $font-weight-semibold;
}

.aqi-text-hazardous {
  color: $airsen-maroon-hazardous;
  font-weight: $font-weight-semibold;
}

// AQI Gradient Classes
.aqi-gradient-good {
  background: linear-gradient(135deg, $airsen-green-good 0%, color.adjust($airsen-green-good, $lightness: 10%) 100%);
  color: white;
}

.aqi-gradient-moderate {
  background: linear-gradient(135deg, $airsen-yellow-moderate 0%, color.adjust($airsen-yellow-moderate, $lightness: 10%) 100%);
  color: $airsen-gray-900;
}

.aqi-gradient-sensitive {
  background: linear-gradient(135deg, $airsen-orange-sensitive 0%, color.adjust($airsen-orange-sensitive, $lightness: 10%) 100%);
  color: white;
}

.aqi-gradient-unhealthy {
  background: linear-gradient(135deg, $airsen-red-unhealthy 0%, color.adjust($airsen-red-unhealthy, $lightness: 10%) 100%);
  color: white;
}

.aqi-gradient-very-unhealthy {
  background: linear-gradient(135deg, $airsen-purple-very 0%, color.adjust($airsen-purple-very, $lightness: 10%) 100%);
  color: white;
}

.aqi-gradient-hazardous {
  background: linear-gradient(135deg, $airsen-maroon-hazardous 0%, color.adjust($airsen-maroon-hazardous, $lightness: 10%) 100%);
  color: white;
}

// AQI Scale/Gradient Bar
.aqi-scale {
  height: 24px;
  border-radius: $radius-full;
  background: linear-gradient(to right,
      $airsen-green-good 0%,
      $airsen-yellow-moderate 16.67%,
      $airsen-orange-sensitive 33.33%,
      $airsen-red-unhealthy 50%,
      $airsen-purple-very 66.67%,
      $airsen-maroon-hazardous 100%);
  box-shadow: $shadow-md;
}

// AQI Status Box Container
.aqi-status-box {
  padding: $space-6;
  border-radius: $radius-lg;
  display: flex;
  align-items: center;
  gap: $space-4;
  transition: $transition-all;

  &.pulse {
    animation: aqi-pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }
}

// AQI Label with Level
.aqi-label {
  display: inline-flex;
  align-items: center;
  gap: $space-2;
  padding: $space-2 $space-4;
  border-radius: $radius-md;
  font-weight: $font-weight-semibold;
  font-size: $font-size-sm;
  white-space: nowrap;
}

// =============================================================================
// ANIMATIONS
// =============================================================================

@keyframes aqi-pulse {

  0%,
  100% {
    box-shadow: 0 0 0 0 rgba(76, 175, 80, 0.7);
  }

  50% {
    box-shadow: 0 0 0 10px rgba(76, 175, 80, 0);
  }
}

// =============================================================================
// RESPONSIVE ADJUSTMENTS FOR AQI COMPONENTS
// =============================================================================

@media (max-width: $breakpoint-sm) {

  .aqi-badge-good,
  .aqi-badge-moderate,
  .aqi-badge-sensitive,
  .aqi-badge-unhealthy,
  .aqi-badge-very-unhealthy,
  .aqi-badge-hazardous {
    padding: $space-1 $space-2;
    font-size: $font-size-xs;
  }

  .aqi-status-box {
    padding: $space-4;
    flex-direction: column;
    text-align: center;
  }

  .aqi-label {
    flex-wrap: wrap;
  }
}

// =============================================================================
// LEGACY COMPATIBILITY ALIASES
// For components still using old variable naming conventions
// TODO: Refactor components to use new design system variable names directly
// =============================================================================

// Background colors
$airsen-background: $airsen-gray-50 !default;

// Text colors
$airsen-text-primary: $airsen-gray-900 !default;
$airsen-text-secondary: $airsen-gray-600 !default;

// Spacing aliases (map new space-* to old spacing-*)
$spacing-xs: $space-2 !default; // 8px
$spacing-sm: $space-3 !default; // 12px
$spacing-md: $space-4 !default; // 16px
$spacing-lg: $space-6 !default; // 24px
$spacing-xl: $space-8 !default; // 32px
$spacing-xxl: $space-12 !default; // 48px

// Border radius aliases (already defined, but included for completeness)
$border-radius-sm: $radius-sm !default;
$border-radius-md: $radius-md !default;
$border-radius-lg: $radius-lg !default;

// Note: $shadow-sm, $shadow-md, $shadow-lg already exist in design system
