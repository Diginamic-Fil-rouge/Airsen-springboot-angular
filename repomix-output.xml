              {{ commune.currentAirQuality?.atmoIndex }}
            </div>
          </div>
        </div>
      </div>

      <!-- No Results -->
      <div class="no-results" *ngIf="communes.length === 0 && hasTyped && !isLoading && !searchError">
        <mat-icon>search_off</mat-icon>
        <p>Aucune commune trouvée</p>
