<div class="change-password-container">
  <form [formGroup]="passwordForm" (ngSubmit)="onSubmit()">
    <!-- Current Password -->
    <mat-form-field appearance="outline" class="full-width">
      <mat-label>Mot de passe actuel</mat-label>
      <input
        matInput
        [type]="showCurrentPassword ? 'text' : 'password'"
        formControlName="currentPassword"
        placeholder="Entrez votre mot de passe actuel"
      />
      <mat-icon matPrefix>lock</mat-icon>
      <button
        mat-icon-button
        matSuffix
        type="button"
        (click)="toggleCurrentPasswordVisibility()"
        [attr.aria-label]="'Hide password'"
      >
        <mat-icon>{{ showCurrentPassword ? 'visibility' : 'visibility_off' }}</mat-icon>
      </button>
      <mat-error *ngIf="passwordForm.get('currentPassword')?.invalid && passwordForm.get('currentPassword')?.touched">
        {{ currentPasswordError }}
      </mat-error>
    </mat-form-field>

    <!-- New Password -->
    <mat-form-field appearance="outline" class="full-width">
      <mat-label>Nouveau mot de passe</mat-label>
      <input
        matInput
        [type]="showNewPassword ? 'text' : 'password'"
        formControlName="newPassword"
        placeholder="Entrez votre nouveau mot de passe"
      />
      <mat-icon matPrefix>vpn_key</mat-icon>
      <button
        mat-icon-button
        matSuffix
        type="button"
        (click)="toggleNewPasswordVisibility()"
        [attr.aria-label]="'Hide password'"
      >
        <mat-icon>{{ showNewPassword ? 'visibility' : 'visibility_off' }}</mat-icon>
      </button>
      <mat-error *ngIf="passwordForm.get('newPassword')?.invalid && passwordForm.get('newPassword')?.touched">
        {{ newPasswordError }}
      </mat-error>
    </mat-form-field>

    <!-- Password Strength Indicator -->
    <div class="password-strength" *ngIf="passwordStrength && passwordForm.get('newPassword')?.value">
      <div class="strength-label">
        <span>Force du mot de passe :</span>
        <span class="strength-message" [style.color]="passwordStrength.color">{{ passwordStrength.message }}</span>
      </div>

      <!-- Progress Bar -->
      <mat-progress-bar
        mode="determinate"
        [value]="passwordStrength.score"
        [color]="passwordStrength.strength === 'STRONG' || passwordStrength.strength === 'GOOD' ? 'primary' : 'warn'"
        [style.--mdc-linear-progress-active-indicator-color]="passwordStrength.color"
      ></mat-progress-bar>

      <!-- Strength Criteria -->
      <div class="strength-criteria">
        <div class="criterion" [class.met]="passwordStrength.hasMinLength">
          <mat-icon>{{ passwordStrength.hasMinLength ? 'check_circle' : 'cancel' }}</mat-icon>
          <span>Au moins 8 caractères</span>
        </div>
        <div class="criterion" [class.met]="passwordStrength.hasUpperCase">
          <mat-icon>{{ passwordStrength.hasUpperCase ? 'check_circle' : 'cancel' }}</mat-icon>
          <span>Une majuscule</span>
        </div>
        <div class="criterion" [class.met]="passwordStrength.hasLowerCase">
          <mat-icon>{{ passwordStrength.hasLowerCase ? 'check_circle' : 'cancel' }}</mat-icon>
          <span>Une minuscule</span>
        </div>
        <div class="criterion" [class.met]="passwordStrength.hasNumbers">
          <mat-icon>{{ passwordStrength.hasNumbers ? 'check_circle' : 'cancel' }}</mat-icon>
          <span>Un chiffre</span>
        </div>
        <div class="criterion" [class.met]="passwordStrength.hasSpecialChars">
          <mat-icon>{{ passwordStrength.hasSpecialChars ? 'check_circle' : 'cancel' }}</mat-icon>
          <span>Un caractère spécial</span>
        </div>
      </div>
    </div>

    <!-- Confirm Password -->
    <mat-form-field appearance="outline" class="full-width">
      <mat-label>Confirmer le mot de passe</mat-label>
      <input
        matInput
        [type]="showConfirmPassword ? 'text' : 'password'"
        formControlName="confirmPassword"
        placeholder="Confirmez votre nouveau mot de passe"
      />
      <mat-icon matPrefix>check_circle</mat-icon>
      <button
        mat-icon-button
        matSuffix
        type="button"
        (click)="toggleConfirmPasswordVisibility()"
        [attr.aria-label]="'Hide password'"
      >
        <mat-icon>{{ showConfirmPassword ? 'visibility' : 'visibility_off' }}</mat-icon>
      </button>
      <mat-error *ngIf="passwordForm.get('confirmPassword')?.invalid && passwordForm.get('confirmPassword')?.touched">
        {{ confirmPasswordError }}
      </mat-error>
    </mat-form-field>

    <!-- Form Actions -->
    <div class="form-actions">
      <button
        type="button"
        mat-stroked-button
        color="warn"
        (click)="onCancel()"
        [disabled]="isSubmitting"
      >
        <mat-icon>cancel</mat-icon>
        Annuler
      </button>

      <button
        type="submit"
        mat-raised-button
        color="primary"
        [disabled]="passwordForm.invalid || isSubmitting"
      >
        <mat-icon>save</mat-icon>
        {{ isSubmitting ? 'Modification...' : 'Modifier' }}
      </button>
    </div>
  </form>
</div>
