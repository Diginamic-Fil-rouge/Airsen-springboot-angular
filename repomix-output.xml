/**
 * Skeleton Loader Component Styles
 *
 * Provides placeholder animations for loading states.
 * Supports pulse and shimmer animations.
 */

@use '../../../../styles/design-system' as *;

// ============================================================================
// Base Skeleton Styles
// ============================================================================

.skeleton-loader {
  background-color: $airsen-gray-200;
  border-radius: $radius-md;
  display: block;
  min-height: 16px;
  width: 100%;

  // Prevent text selection
  user-select: none;
  pointer-events: none;

  // Hardware acceleration
  @include gpu-acceleration;
}

// ============================================================================
// Animation: Pulse
// ============================================================================

.skeleton-pulse {
  animation: skeleton-pulse 2s ease-in-out infinite;
}

@keyframes skeleton-pulse {
  0%,
  100% {
    background-color: $airsen-gray-200;
  }
  50% {
    background-color: $airsen-gray-300;
  }
}

// ============================================================================
// Animation: Shimmer
// ============================================================================

.skeleton-shimmer {
  background: linear-gradient(
    90deg,
    $airsen-gray-200 0%,
    $airsen-gray-100 50%,
    $airsen-gray-200 100%
  );
  background-size: 200% 100%;
  background-position: 100% 0;
  animation: skeleton-shimmer 2s infinite;
}

@keyframes skeleton-shimmer {
  0% {
    background-position: 100% 0;
  }
  100% {
    background-position: -100% 0;
  }
}

// ============================================================================
// Type-Specific Styles
// ============================================================================

// Line skeleton (single short line)
.skeleton-line {
  height: 16px;
  border-radius: $radius-md;
}

// Avatar skeleton (circular)
.skeleton-avatar {
  border-radius: 50%;
  width: 48px;
  height: 48px;
  flex-shrink: 0;
}

// Badge skeleton (small pill)
.skeleton-badge {
  height: 24px;
  border-radius: $radius-full;
  width: 80px;
}

// Button skeleton
.skeleton-button {
  height: 40px;
  border-radius: $radius-md;
  width: 120px;
}

// Circle skeleton (perfect circle)
.skeleton-circle {
  border-radius: 50%;
  aspect-ratio: 1;
}

// ============================================================================
// Paragraph Container
// ============================================================================

.skeleton-paragraph {
  width: 100%;

  // Space between lines
  & > .skeleton-loader:not(:last-child) {
    margin-bottom: $space-2;
  }

  // Last line is usually shorter
  & > .skeleton-loader:last-child {
    width: 80%;
  }
}

// ============================================================================
// Card Skeleton Layout
// ============================================================================

.skeleton-card {
  @include card();
  display: flex;
  flex-direction: column;
  gap: $space-6;

  // Remove card shadow on skeleton
  box-shadow: $shadow-sm;
  border: 1px solid $airsen-gray-100;

  .skeleton-card-header {
    display: flex;
    align-items: flex-start;
    gap: $space-4;

    .skeleton-loader {
      flex-shrink: 0;
    }

    & > div {
      flex: 1;
    }
  }

  .skeleton-card-body {
    display: flex;
    flex-direction: column;
    gap: $space-2;

    & > .skeleton-loader {
      height: 16px;
    }

    & > .skeleton-loader:last-child {
      width: 85%;
    }
  }

  .skeleton-card-footer {
    display: flex;
    gap: $space-4;
    margin-top: auto;

    & > .skeleton-loader {
      flex: 1;
      height: 36px;
    }
  }
}

// ============================================================================
// Responsive Adjustments
// ============================================================================

@include respond-max(sm) {
  .skeleton-card {
    padding: $space-4;
    gap: $space-4;

    .skeleton-card-header {
      gap: $space-2;

      .skeleton-loader {
        width: 40px;
        height: 40px;
      }
    }

    .skeleton-card-footer {
      flex-direction: column;

      & > .skeleton-loader {
        width: 100%;
      }
    }
  }

  .skeleton-paragraph {
    & > .skeleton-loader:last-child {
      width: 75%;
    }
  }
}

// ============================================================================
// Accessibility
// ============================================================================

// Reduced motion support (no animation)
@media (prefers-reduced-motion: reduce) {
  .skeleton-pulse,
  .skeleton-shimmer {
    animation: none;
    background-color: $airsen-gray-200;
    background-image: none;
  }

  .skeleton-shimmer {
    opacity: 0.6;
  }
}

// Dark mode support (if implemented)
@media (prefers-color-scheme: dark) {
  .skeleton-loader {
    background-color: $airsen-gray-700;
  }

  .skeleton-pulse {
    // Pulse animation handled in keyframes above
    background-color: $airsen-gray-700;
  }

  .skeleton-shimmer {
    background: linear-gradient(
      90deg,
      $airsen-gray-700 0%,
      $airsen-gray-600 50%,
      $airsen-gray-700 100%
    );
  }
}
</file>

<file path="airsen-frontend/src/app/shared/models/air-quality.model.ts">
export interface AirQualityData {
  inseeCode: string;
  commune: string;
  aqi: number;
  aqiLabel: string;
  aqiColor: string;
  pm25?: number;
  pm10?: number;
  o3?: number;
  no2?: number;
  timestamp: Date;
}

/**
 * Detailed air quality measurements with individual pollutants
 */
export interface AirQuality {
  id: number;
  communeId: number;
  latitude: number;
  longitude: number;
  measurementDate: Date;
  globalIndex: number;
  globalQuality: AirQualityLevel;
  no2: number;
  no2Quality: AirQualityLevel;
  o3: number;
  o3Quality: AirQualityLevel;
  pm10: number;
  pm10Quality: AirQualityLevel;
  pm25: number;
  pm25Quality: AirQualityLevel;
  so2: number;
  so2Quality: AirQualityLevel;
  createdAt: Date;
  updatedAt: Date;
