                width: $font-size-lg;
                height: $font-size-lg;
              }
            }
          }
        }
      }
    }
  }

  // ===========================================================================
  // RESPONSIVE DESIGN - Mobile-first approach
  // ===========================================================================

  // Tablet (768px+)
  @media (max-width: $breakpoint-md) {
    padding: $space-4; // 16px

    .profile-header {
      flex-direction: column;
      text-align: center;
      gap: $space-4; // 16px
      padding: $space-5; // 20px

      .avatar-section {
