  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  z-index: $z-index-modal-backdrop - 10;
  animation: fadeIn $duration-normal $ease-in-out;
  cursor: pointer;
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

// Responsive Design
// Tablet and below: Sidebar becomes overlay
@include respond-max(lg) {
  .sidebar {
    transform: translateX(-100%);
    z-index: $z-index-modal - 5;

    &:not(.collapsed) {
      transform: translateX(0);
    }
  }

  .sidebar-toggle {
    display: none; // Hide toggle button on mobile, use backdrop to close
  }
}

// Mobile: Wider sidebar overlay
@include respond-max(md) {
  .sidebar {
    width: $sidebar-width-mobile;
    box-shadow: $shadow-xl;

    &.collapsed {
      width: $sidebar-width-mobile;
    }
  }
}

// Small mobile: Full width sidebar
@include respond-max(sm) {
  .sidebar {
    width: 100%;

    &.collapsed {
      width: 100%;
    }
  }

  .sidebar-header {
    padding: $space-4;
    min-height: 100px;

    .user-avatar {
      width: 56px;
      height: 56px;

      .avatar-initial {
        font-size: $font-size-xl;
      }
    }
  }

  .nav-section {
    padding: 0 $space-3;
  }

  .sidebar-footer {
    padding: $space-4;
  }
}

// Accessibility

// Keyboard navigation focus styles
.nav-item:focus-visible {
  @include focus-ring();
  outline-offset: 2px;
}

.logout-btn:focus-visible {
  @include focus-ring();
}

.sidebar-toggle:focus-visible {
  @include focus-ring();
}

// Reduced motion support
@media (prefers-reduced-motion: reduce) {
  .sidebar,
  .sidebar-header .user-info,
  .section-title,
  .nav-item,
  .nav-item span,
  .logout-btn span,
  .sidebar-credit,
  .sidebar-toggle,
  .sidebar-backdrop {
    transition: none;
    animation: none;
  }
}
