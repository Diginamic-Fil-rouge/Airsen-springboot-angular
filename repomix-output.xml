@use 'sass:color';
@use 'styles/design-system' as *;

.admin-dashboard {
  max-width: 1400px;
  margin: 0 auto;
  padding: $space-6;

  @include respond-max(md) {
    padding: $space-4;
  }
}

// Header Section
.dashboard-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: $space-8;

  @include respond-max(md) {
    flex-direction: column;
    align-items: flex-start;
    gap: $space-4;
  }

  h2 {
    font-size: $font-size-3xl;
    font-weight: $font-weight-semibold;
    color: $airsen-gray-900;
    margin: 0;
  }

  button {
    display: flex;
    align-items: center;
    gap: $space-2;
  }
}

// Loading and Error States
.loading-state,
.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: $space-16 $space-8;
  text-align: center;

  p {
    margin: $space-4 0 0 0;
    color: $airsen-gray-600;
    font-size: $font-size-lg;
  }

  mat-icon {
    font-size: 48px;
    width: 48px;
    height: 48px;
    margin-bottom: $space-4;
  }

  button {
    margin-top: $space-4;
  }
}

// Statistics Grid
.stats-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
  gap: $space-6;
  margin-bottom: $space-8;

  @include respond-max(md) {
    grid-template-columns: 1fr;
    gap: $space-4;
  }
}

// Stat Cards using Material Cards
.stat-card {
  @include card();
  transition: transform $duration-normal $ease-in-out, box-shadow $duration-normal $ease-in-out;

  &:hover {
    transform: translateY(-2px);
    box-shadow: $shadow-lg;
  }

  mat-card-content {
    display: flex;
    align-items: center;
    gap: $space-4;
    padding: $space-6 !important;
  }
}

.stat-icon {
  width: 64px;
  height: 64px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: $radius-lg;
  background-color: rgba($airsen-gray-100, 0.8);
  flex-shrink: 0;

  mat-icon {
    font-size: 32px;
    width: 32px;
    height: 32px;
  }
