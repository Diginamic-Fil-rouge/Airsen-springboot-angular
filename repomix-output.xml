    timezone: ${WEATHER_SCHEDULE_TIMEZONE:Europe/Paris}
    batch-size: ${WEATHER_BATCH_SIZE:100}
    delay-between-batches-ms: ${WEATHER_BATCH_DELAY:60000}  # 1 minute
    delay-between-requests-ms: ${WEATHER_REQUEST_DELAY:6000}  # 6 seconds (~10 requests/min)

# Custom application email settings
airsen:
  mail:
    from:
      address: ${MAIL_FROM_ADDRESS:noreply@airsen.fr}
      name: ${MAIL_FROM_NAME:Airsen Air Quality System}

# Profile-specific configurations are now in separate files:
# - application-dev.yml: Development settings (relaxed schedules, verbose logging)
# - application-test.yml: Testing settings (disabled scheduling, mocked APIs)
# - application-prod.yml: Production settings (full schedules, optimized performance)
