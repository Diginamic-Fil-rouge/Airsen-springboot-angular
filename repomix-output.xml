<section class="stats-panel">
  <h2>Votre Activité</h2>

  <div class="stats-content">
    <!-- Chart Section -->
    <div class="chart-container">
      <canvas baseChart [data]="doughnutChartData" [type]="doughnutChartType" [options]="doughnutChartOptions">
