    font-size: $font-size-sm;
    font-weight: $font-weight-semibold;
    color: $airsen-gray-600;
    text-transform: uppercase;
    letter-spacing: $letter-spacing-wide;
    margin: 0 0 $space-2 0;
  }

  .stat-number {
    font-size: $font-size-data;
    font-weight: $font-weight-bold;
    color: $airsen-gray-900;
    margin: 0 0 $space-3 0;
    line-height: $line-height-tight;
  }

  .stat-subtitle {
    font-size: $font-size-sm;
    color: $airsen-gray-600;
    margin: 0;
    line-height: $line-height-normal;
  }
}

.stat-details {
  display: flex;
  gap: $space-2;
  flex-wrap: wrap;
  margin-top: $space-2;

  mat-chip {
    font-size: $font-size-xs;
    font-weight: $font-weight-medium;
    height: 28px;
  }
}

// Color variants for stat cards
.stat-card-primary {
  .stat-icon {
    background-color: rgba($airsen-primary, 0.1);
  }
}

.stat-card-success {
  .stat-icon {
    background-color: rgba($airsen-success, 0.1);
  }
}

.stat-card-warning {
  .stat-icon {
    background-color: rgba($airsen-warning, 0.1);
  }
}

.stat-card-info {
  .stat-icon {
    background-color: rgba($airsen-secondary, 0.1);
  }
