    private ForumVoteRepository repository;

    private User user1;
    private User user2;
    private ForumThread thread1;
    private ForumVote vote1;
    private ForumVote vote2;

    @BeforeEach
    void setUp() {
        user1 = new User();
        user1.setId(1L);
        user1.setFirstName("alice");
        user1.setLastName("vanneneker");

        user2 = new User();
