<div class="profile-container">
  <!-- Profile Header -->
  <div class="profile-header">
    <div class="avatar-section">
      <!-- Initials-based Avatar -->
      <div class="avatar-circle">
        <span class="avatar-initials">{{ userInitials }}</span>
      </div>
    </div>

    <div class="user-info">
      <h2 class="user-name">{{ userFullName }}</h2>
      <p class="user-email">{{ userProfile?.email }}</p>
      <p class="user-role">
        <mat-icon>{{ userProfile?.role === 'ADMIN' ? 'admin_panel_settings' : 'person' }}</mat-icon>
        {{ userProfile?.role === 'ADMIN' ? 'Administrateur' : 'Utilisateur' }}
      </p>
    </div>
  </div>

  <!-- Loading State -->
  <div *ngIf="isLoadingProfile" class="loading-container">
    <mat-spinner diameter="50"></mat-spinner>
    <p>Chargement du profil...</p>
  </div>

  <!-- Main Content with Tabs -->
  <div *ngIf="!isLoadingProfile" class="profile-content">
    <mat-tab-group animationDuration="300ms" dynamicHeight>
      <!-- Tab 1: Personal Information -->
      <mat-tab>
        <ng-template mat-tab-label>
          <mat-icon>person</mat-icon>
          Informations personnelles
        </ng-template>

        <div class="tab-content">
          <app-info-form
            [user]="userProfile"
            (profileUpdate)="onProfileUpdate($event)"
          ></app-info-form>
        </div>
      </mat-tab>

      <!-- Tab 2: Security (Password Change) -->
      <mat-tab>
        <ng-template mat-tab-label>
          <mat-icon>security</mat-icon>
          Sécurité
        </ng-template>

        <div class="tab-content">
          <div class="security-header">
            <h3>Modifier le mot de passe</h3>
            <p>Assurez-vous d'utiliser un mot de passe fort et unique</p>
          </div>

          <app-change-password
            (passwordChange)="onPasswordChange($event)"
          ></app-change-password>
        </div>
      </mat-tab>

      <!-- Tab 3: Notifications (Received + Preferences) -->
      <mat-tab>
        <ng-template mat-tab-label>
          <mat-icon [matBadge]="unreadNotificationCount > 0 ? unreadNotificationCount : null" matBadgeColor="warn">notifications</mat-icon>
          Notifications
        </ng-template>

        <div class="tab-content notifications-tab">
          <!-- Section 1: Received Notifications (Admin Broadcasts) -->
          <div class="notifications-section">
            <div class="section-header">
              <h3>
                <mat-icon>campaign</mat-icon>
                Alertes reçues
              </h3>
              <p>Notifications environnementales diffusées par les administrateurs</p>
            </div>

            <!-- Loading State -->
            <div *ngIf="isLoadingNotifications" class="loading-state">
              <mat-spinner diameter="40"></mat-spinner>
              <p>Chargement des notifications...</p>
            </div>

            <!-- Received Notifications List -->
            <div *ngIf="!isLoadingNotifications" class="notifications-list">
              <!-- Empty State -->
              <div *ngIf="receivedNotifications.length === 0" class="empty-state">
                <mat-icon>notifications_none</mat-icon>
                <p>Aucune notification reçue</p>
                <span class="empty-state-hint">Les alertes environnementales apparaîtront ici</span>
              </div>

              <!-- Notification Cards -->
              <mat-card *ngFor="let notification of receivedNotifications" class="notification-card">
                <mat-card-header>
                  <div mat-card-avatar class="notification-icon" [class]="notification.status.toLowerCase()">
                    <mat-icon>{{ notification.status === 'PENDING' ? 'notifications_active' : notification.status === 'SENT' ? 'check_circle' : 'error' }}</mat-icon>
                  </div>
                  <mat-card-title>Alerte environnementale #{{ notification.campaignId }}</mat-card-title>
                  <mat-card-subtitle>
                    {{ notification.recipientEmail }} · {{ notification.createdAt | date:'dd/MM/yyyy à HH:mm' }}
                  </mat-card-subtitle>
                </mat-card-header>

                <mat-card-content>
                  <div class="notification-status">
                    <mat-chip [class]="notification.status.toLowerCase()">
                      {{ notification.status === 'PENDING' ? 'En attente' : notification.status === 'SENT' ? 'Envoyée' : 'Échec' }}
                    </mat-chip>
                  </div>

                  <p *ngIf="notification.failedAt && notification.errorMessage" class="error-message">
                    <mat-icon>error</mat-icon>
                    {{ notification.errorMessage }}
                  </p>
                </mat-card-content>
              </mat-card>
            </div>
          </div>

          <mat-divider></mat-divider>

          <!-- Section 2: Notification Preferences -->
          <div class="preferences-section">
            <div class="section-header">
              <h3>
                <mat-icon>tune</mat-icon>
                Préférences de notification
              </h3>
              <p>Personnalisez vos préférences de notification</p>
            </div>

            <app-notification-toggle
              *ngIf="currentUser"
              [userId]="currentUser.id"
              (settingsChange)="onNotificationSettingsChange($event)"
            ></app-notification-toggle>
          </div>
        </div>
      </mat-tab>
    </mat-tab-group>
  </div>
</div>
