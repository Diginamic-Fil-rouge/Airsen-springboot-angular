// =============================================================================
// UTILITY FUNCTIONS
// =============================================================================

// Function to get color from maps
@function color($palette, $tone: null) {
  @if $tone ==null {
    @return map-get($brand-colors, $palette
  );
}

@if $palette =="gray" {
  @return map-get($gray-colors, $tone);
}

@if $palette =="air-quality" {
  @return map-get($air-quality-colors, $tone);
}

@return null;
}

// Function to get spacing value
@function space($size) {
  @return map-get($spacing, $size);
}

// Function to get font size
@function font-size($size) {
  @return map-get($font-sizes, $size);
}

// Function to get shadow
@function shadow($size) {
  @return map-get($shadows, $size);
}

// Function to get border radius
@function radius($size) {
  @return map-get($radius, $size);
}

// =============================================================================
// MIXINS
// =============================================================================

// Responsive breakpoint mixin (min-width)
@mixin breakpoint($size) {
  @if map.has-key($breakpoints, $size) {
    @media (min-width: map.get($breakpoints, $size)) {
      @content;
    }
  }

  @else {
    @warn "Unknown breakpoint: #{$size}";
  }
}

// Responsive breakpoint mixin (max-width)
@mixin respond-max($size) {
  @if map.has-key($breakpoints, $size) {
    @media (max-width: map.get($breakpoints, $size) - 1px) {
      @content;
    }
  }

  @else {
    @warn "Unknown breakpoint: #{$size}";
  }
}

// Focus ring mixin
@mixin focus-ring() {
  outline: none;
  box-shadow: $shadow-focus;
}

// Card mixin
@mixin card() {
  background: $card-background;
  border-radius: $card-border-radius;
  box-shadow: $card-shadow;
  padding: $card-padding;
  transition: box-shadow $duration-normal $ease-in-out;

  &:hover {
    box-shadow: $card-shadow-hover;
  }
}

// Button mixin
@mixin button($variant: "primary", $size: "md") {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border: none;
  border-radius: $btn-border-radius;
  font-weight: $btn-font-weight;
  cursor: pointer;
  transition: $transition-all;
  text-decoration: none;

  @if $size =="sm" {
    padding: $btn-padding-sm;
    font-size: $btn-font-size-sm;
  }

  @else if $size =="lg" {
    padding: $btn-padding-lg;
    font-size: $btn-font-size-lg;
  }

  @else {
    padding: $btn-padding-md;
    font-size: $btn-font-size-md;
  }

  @if $variant =="primary" {
    background: $airsen-primary;
    color: $airsen-white;

    &:hover:not(:disabled) {
      background: $airsen-primary-dark;
      transform: translateY(-1px);
    }
  }

  @else if $variant =="secondary" {
    background: transparent;
    color: $airsen-primary;
    border: 2px solid $airsen-primary;

    &:hover:not(:disabled) {
      background: $airsen-primary;
      color: $airsen-white;
    }
  }

  &:focus {
    @include focus-ring();
  }

  &:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }
}

// Air quality color mixin
@mixin air-quality-color($level) {
  @if $level =="good" {
    background-color: $airsen-green-good;
    color: $airsen-white;
  }

  @else if $level =="moderate" {
    background-color: $airsen-yellow-moderate;
    color: $airsen-gray-900;
  }

  @else if $level =="sensitive" {
    background-color: $airsen-orange-sensitive;
    color: $airsen-white;
  }

  @else if $level =="unhealthy" {
    background-color: $airsen-red-unhealthy;
    color: $airsen-white;
  }

  @else if $level =="very-unhealthy" {
    background-color: $airsen-purple-very;
    color: $airsen-white;
  }

  @else if $level =="hazardous" {
    background-color: $airsen-maroon-hazardous;
    color: $airsen-white;
  }
}

// Screen reader only mixin
@mixin sr-only() {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}

// Truncate text mixin
@mixin truncate() {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

// Multiline text truncation (clamp lines)
@mixin multiline-truncate($lines: 2) {
  display: -webkit-box;
  -webkit-line-clamp: $lines;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

// Aspect ratio container (for images, videos)
@mixin aspect-ratio($width: 1, $height: 1) {
  position: relative;
  padding-bottom: calc(($height / $width) * 100%);

  >* {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }
}

// Absolute centering (position: absolute)
@mixin absolute-center($z-index: null) {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);

  @if $z-index {
    z-index: $z-index;
  }
}

// Custom scrollbar styling (webkit only)
@mixin custom-scrollbar($thumb-bg: $airsen-gray-300, $track-bg: $airsen-gray-100) {
  &::-webkit-scrollbar {
    width: 8px;
    height: 8px;
  }

  &::-webkit-scrollbar-track {
    background: $track-bg;
  }

  &::-webkit-scrollbar-thumb {
    background: $thumb-bg;
    border-radius: $radius-full;

    &:hover {
      background: $airsen-gray-400;
    }
  }
}

// Hardware acceleration mixin
@mixin gpu-acceleration {
  transform: translate3d(0, 0, 0);
  backface-visibility: hidden;
  perspective: 1000px;
}

