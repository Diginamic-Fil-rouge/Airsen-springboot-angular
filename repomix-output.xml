/* From Uiverse.io by terenceodonoghue */ 
.container {
  margin: 10% auto;
  border-radius: 50%;
  height: 50px;
  width: 50px;
  animation: rotate_3922 1.2s linear infinite;
  background-color: $airsen-primary-light;
  background-image: linear-gradient($airsen-primary-light, $airsen-secondary-light, $airsen-accent);
  
  span {
    margin: 0 auto;

    border-radius: 50%;
    height: 100%;
    width: 100%;
    background-color: $airsen-primary-light;
    background-image: linear-gradient($airsen-primary-light, $airsen-secondary-light, $airsen-accent);
}

}

.container span:nth-of-type(1) {
  filter: blur(5px);
}

.container span:nth-of-type(2) {
  filter: blur(10px);
}

.container span:nth-of-type(3) {
  filter: blur(25px);
}

.container span:nth-of-type(4) {
  filter: blur(50px);
}

.container::after {
  content: "";
  position: absolute;
  top: 10px;
  left: 10px;
  right: 10px;
  bottom: 10px;
  background-color: #fff;
  border: solid 5px #ffffff;
  border-radius: 50%;
}

@keyframes rotate_3922 {
  from {
    transform: translate(-50%, -50%) rotate(0deg);
  }

  to {
    transform: translate(-50%, -50%) rotate(360deg);
  }
}
