<div class="dashboard-page">
  <div *ngIf="isLoading" class="loading-container">
    <mat-spinner diameter="50"></mat-spinner>
    <p>Chargement de votre tableau de bord...</p>
  </div>

  <ng-container *ngIf="!isLoading && currentUser">
    <!-- Hero Section: Current Conditions -->
    <section class="hero-card" *ngIf="primaryFavoriteAqi; else welcomeFallback"
      [style.background-color]="primaryFavoriteAqi.color || 'var(--color-primary)'" [style.color]="'white'">
      <div class="hero-content">
        <div class="hero-main">
          <h2>{{ primaryFavoriteAqi.commune }}</h2>
          <div class="aqi-display">
            <span class="aqi-value">{{ primaryFavoriteAqi.globalIndex }}</span>
            <span class="aqi-label">{{ primaryFavoriteAqi.qualifier }}</span>
          </div>
        </div>
        <div class="hero-weather" *ngIf="primaryFavoriteWeather">
          <div class="weather-temp">
            <mat-icon>thermostat</mat-icon>
            <span>{{ primaryFavoriteWeather.temperature }}°C</span>
          </div>
          <div class="weather-detail">
            <mat-icon>water_drop</mat-icon>
            <span>{{ primaryFavoriteWeather.humidity }}%</span>
          </div>
          <div class="weather-detail">
            <mat-icon>air</mat-icon>
            <span>{{ primaryFavoriteWeather.windSpeed }} km/h</span>
          </div>
        </div>
      </div>
      <div class="hero-footer">
        <p>Mise à jour : {{ currentDateTime | date:'shortTime' }}</p>
      </div>
    </section>

    <ng-template #welcomeFallback>
      <section class="welcome-card">
        <div class="welcome-details">
          <div class="welcome-avatar">{{ avatarInitials }}</div>
          <div class="welcome-text">
            <p class="welcome-greeting">Bon retour, {{ welcomeName }} !</p>
            <p class="welcome-meta">
              {{ currentDateTime | date:'fullDate' }} · {{ currentDateTime | date:'shortTime' }}
            </p>
          </div>
        </div>
      </section>
    </ng-template>

    <app-quick-actions [actions]="quickActions" (actionClick)="onQuickAction($event)"></app-quick-actions>

    <div class="dashboard-grid">
      <app-alert-summary [alerts]="recentAlerts" [showPagination]="false" [showFavoritesFilter]="true"
        (alertClick)="onAlertClick($event)" (viewAllAlerts)="onViewAllAlerts()"
        (filterByFavorites)="onFilterAlertsByFavorites()"></app-alert-summary>

      <app-stats-panel [stats]="userStats" [favorites]="favorites" [showProgressBar]="true"
        (statClick)="onStatClick($event)"></app-stats-panel>
    </div>
  </ng-container>

  <div *ngIf="!isLoading && !currentUser" class="error-container">
    <mat-icon>error_outline</mat-icon>
    <h2>Impossible de charger le tableau de bord</h2>
    <p>Veuillez réessayer de vous connecter</p>
    <button mat-raised-button color="primary" (click)="logout()">
      Retour à la Connexion
    </button>
  </div>
</div>
