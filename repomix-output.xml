    font-size: $font-size-base;
    font-weight: $font-weight-medium;
    text-decoration: none;
    border-radius: $radius-md;
    transition: $transition-all;

    &:hover {
      transform: translateY(-1px);
      box-shadow: $shadow-sm;
    }

